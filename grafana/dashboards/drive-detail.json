{
  "title": "Drive Health \u2014 Drive Detail",
  "uid": "drive-health-drive-detail",
  "description": "Per-drive deep dive. Select a host and drive to investigate SMART attributes, temperature trends, and I/O performance.",
  "tags": [
    "homelab",
    "storage",
    "smartmon"
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "graphTooltip": 1,
  "links": [
    {
      "title": "Fleet Overview",
      "url": "/d/drive-health-fleet-overview",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Security & Anomaly",
      "url": "/d/drive-health-security",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": false,
          "text": "grafanacloud-cew-prom",
          "value": "grafanacloud-prom"
        },
        "refresh": 1,
        "multi": false,
        "includeAll": false,
        "hide": 0
      },
      {
        "name": "logs_datasource",
        "label": "Loki",
        "type": "datasource",
        "query": "loki",
        "current": {
          "selected": false,
          "text": "grafanacloud-cew-logs",
          "value": "grafanacloud-logs"
        },
        "refresh": 1,
        "multi": false,
        "includeAll": false,
        "hide": 0
      },
      {
        "name": "host",
        "label": "Host",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": {
          "query": "label_values(smartctl_device{scsi_product!=\"VIRTUAL-DISK\",device!~\".+megaraid.+\"}, instance)",
          "refId": "A"
        },
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": false
      },
      {
        "name": "drive",
        "label": "Drive",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": {
          "query": "label_values(smartctl_device{instance=\"$host\",scsi_product!=\"VIRTUAL-DISK\",device!~\".+megaraid.+\"}, device)",
          "refId": "A"
        },
        "regex": "",
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "SMART Health",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "smartctl_device_smart_status{instance=\"$host\", device=\"$drive\",device!~\".+megaraid.+\"}",
          "instant": true,
          "legendFormat": "__auto"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "FAILED",
                  "color": "red",
                  "index": 0
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "PASSED",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Temperature",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "smartctl_device_temperature{instance=\"$host\", device=\"$drive\", temperature_type=\"current\",device!~\".+megaraid.+\"}",
          "instant": true,
          "legendFormat": "__auto"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 45
              },
              {
                "color": "red",
                "value": 55
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Power-On Hours",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "smartctl_device_power_on_seconds{instance=\"$host\", device=\"$drive\",device!~\".+megaraid.+\"} / 3600",
          "instant": true,
          "legendFormat": "__auto"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 35040
              },
              {
                "color": "orange",
                "value": 43800
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Power Cycles",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "smartctl_device_power_cycle_count{instance=\"$host\", device=\"$drive\",device!~\".+megaraid.+\"}",
          "instant": true,
          "legendFormat": "__auto"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Drives Monitored",
      "description": "Number of drives smartctl_exporter is actively monitoring on this host. 0 means the exporter is not running or has no drives.",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "count(smartctl_device{instance=\"$host\",scsi_product!=\"VIRTUAL-DISK\",device!~\".+megaraid.+\"})",
          "instant": true,
          "legendFormat": "__auto"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Drive Identity",
      "description": "Device model, serial number, firmware, and capacity from SMART data.",
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "smartctl_device{instance=\"$host\", device=\"$drive\",scsi_product!=\"VIRTUAL-DISK\",device!~\".+megaraid.+\"} * on(instance, device) group_left() smartctl_device_capacity_bytes{instance=\"$host\", device=\"$drive\",device!~\".+megaraid.+\"}",
          "instant": true,
          "legendFormat": "__auto"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": false,
              "job": true,
              "interface": true,
              "protocol": true,
              "ata_version": true,
              "sata_version": true,
              "form_factor": true,
              "rotation_rate": true,
              "smartctl_version": true,
              "__name__": true
            },
            "renameByName": {
              "instance": "Host",
              "device": "Drive",
              "model_name": "Model",
              "model_family": "Model Family",
              "serial_number": "Serial Number",
              "firmware_version": "Firmware",
              "Value": "Size"
            },
            "indexByName": {
              "instance": 0,
              "device": 1,
              "model_name": 2,
              "model_family": 3,
              "serial_number": 4,
              "firmware_version": 5,
              "Value": 6
            }
          }
        }
      ],
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Size"
            },
            "properties": [
              {
                "id": "unit",
                "value": "decbytes"
              },
              {
                "id": "custom.align",
                "value": "left"
              }
            ]
          }
        ]
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Backblaze 5 \u2014 Failure Predictors",
      "description": "The five SMART attributes with the strongest correlation to drive failure. Any increase from zero is significant.",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "smartctl_device_attribute{instance=\"$host\", device=\"$drive\", attribute_name=\"Reallocated_Sector_Ct\",   attribute_value_type=\"raw\",device!~\".+megaraid.+\"}",
          "legendFormat": "Reallocated Sectors (5)"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "smartctl_device_attribute{instance=\"$host\", device=\"$drive\", attribute_name=\"Reported_Uncorrect\",       attribute_value_type=\"raw\",device!~\".+megaraid.+\"}",
          "legendFormat": "Reported Uncorrectable (187)"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "smartctl_device_attribute{instance=\"$host\", device=\"$drive\", attribute_name=\"Command_Timeout\",          attribute_value_type=\"raw\",device!~\".+megaraid.+\"}",
          "legendFormat": "Command Timeout (188)"
        },
        {
          "refId": "D",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "smartctl_device_attribute{instance=\"$host\", device=\"$drive\", attribute_name=\"Current_Pending_Sector\",   attribute_value_type=\"raw\",device!~\".+megaraid.+\"}",
          "legendFormat": "Current Pending Sectors (197)"
        },
        {
          "refId": "E",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "smartctl_device_attribute{instance=\"$host\", device=\"$drive\", attribute_name=\"Offline_Uncorrectable\",    attribute_value_type=\"raw\",device!~\".+megaraid.+\"}",
          "legendFormat": "Offline Uncorrectable (198)"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Temperature Trend",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "smartctl_device_temperature{instance=\"$host\", device=\"$drive\", temperature_type=\"current\",device!~\".+megaraid.+\"}",
          "legendFormat": "Temperature"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 45
              },
              {
                "color": "red",
                "value": 55
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Disk I/O \u2014 IOPS",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 17
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "rate(node_disk_reads_completed_total{instance=\"$host\", device=\"$drive\"}[5m])",
          "legendFormat": "Reads/s"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "rate(node_disk_writes_completed_total{instance=\"$host\", device=\"$drive\"}[5m])",
          "legendFormat": "Writes/s"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "iops",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5
          }
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Disk I/O \u2014 Throughput",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 25
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "rate(node_disk_read_bytes_total{instance=\"$host\", device=\"$drive\"}[5m])",
          "legendFormat": "Read MB/s"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "rate(node_disk_written_bytes_total{instance=\"$host\", device=\"$drive\"}[5m])",
          "legendFormat": "Write MB/s"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5
          }
        },
        "overrides": []
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "I/O Wait Time",
      "description": "Time the drive spends processing I/O. Sustained high values indicate the drive is saturated or degrading.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 25
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "rate(node_disk_io_time_seconds_total{instance=\"$host\", device=\"$drive\"}[5m])",
          "legendFormat": "I/O utilisation"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
        "overrides": []
      }
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}
