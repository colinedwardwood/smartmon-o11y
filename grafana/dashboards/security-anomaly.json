  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "All drives currently reporting SMART data. Compare against your known hardware inventory. An unexpected serial number or a drive disappearing could indicate physical tampering.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "cellOptions": {
              "type": "auto"
            },
            "footer": {
              "reducers": []
            },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Capacity"
            },
            "properties": [
              {
                "id": "unit",
                "value": "decbytes"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "cellHeight": "sm",
        "showHeader": true,
        "sortBy": [
          {
            "desc": false,
            "displayName": "Host"
          }
        ]
      },
      "pluginVersion": "13.0.0-23069273608.patch3",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "smartctl_device{scsi_product!=\"VIRTUAL-DISK\",device!~\".+megaraid.+\"} * on(instance, device) group_left() smartctl_device_capacity_bytes{device!~\".+megaraid.+\"}",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "title": "Drive Inventory",
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "ata_additional_product_id": true,
              "ata_version": true,
              "form_factor": false,
              "interface": true,
              "job": true,
              "protocol": false,
              "rotation_rate": true,
              "sata_version": true,
              "scsi_product": true,
              "scsi_revision": true,
              "scsi_vendor": true,
              "scsi_version": true,
              "smartctl_version": true
            },
            "includeByName": {},
            "indexByName": {
              "Value": 5,
              "device": 1,
              "firmware_version": 4,
              "instance": 0,
              "model_family": 6,
              "model_name": 2,
              "serial_number": 3
            },
            "renameByName": {
              "Value": "Capacity",
              "device": "Drive",
              "firmware_version": "Firmware",
              "instance": "Host",
              "model_family": "Family",
              "model_name": "Model",
              "protocol": "Protocol",
              "sata_version": "Sata Version",
              "serial_number": "Serial Number"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Sustained write rates above normal baseline. Ransomware encryption and bulk exfiltration both produce characteristic sustained write spikes. The 200MB/s reference line is a starting threshold \u2014 tune to your environment.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "barWidthFactor": 0.6,
            "drawStyle": "line",
            "fillOpacity": 5,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "auto",
            "showValues": false,
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "orange",
                "value": 104857600
              },
              {
                "color": "red",
                "value": 209715200
              }
            ]
          },
          "unit": "Bps"
        }
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "id": 2,
      "options": {
        "annotations": {
          "clustering": -1,
          "multiLane": false
        },
        "legend": {
          "calcs": [
            "lastNotNull",
            "max",
            "mean"
          ],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "13.0.0-23069273608.patch3",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "rate(node_disk_written_bytes_total{device!~\"loop.*|dm-.*|.+megaraid.+\"}[5m])",
          "legendFormat": "{{instance}} / {{device}}",
          "refId": "A"
        }
      ],
      "title": "Write Rate per Drive \u2014 Anomaly Monitor",
      "type": "timeseries"
    },
