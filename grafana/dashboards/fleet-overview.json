{
  "title": "Drive Health \u2014 Fleet Overview",
  "uid": "drive-health-fleet-overview",
  "description": "Fleet-wide SMART health status across all monitored hosts. Primary triage view \u2014 open this first.",
  "tags": [
    "homelab",
    "storage",
    "smartmon"
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "graphTooltip": 1,
  "links": [
    {
      "title": "Drive Detail",
      "url": "/d/drive-health-drive-detail",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Security & Anomaly",
      "url": "/d/drive-health-security",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Drives Monitored",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "count(smartctl_device{scsi_product!=\"VIRTUAL-DISK\",device!~\".+megaraid.+\"})",
          "instant": true,
          "legendFormat": "__auto"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "SMART Failures",
      "description": "Drives where overall SMART health = FAILED. Any non-zero value requires immediate attention.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "count((smartctl_device_smart_status{device!~\".+megaraid.+\"} unless on(instance, device) smartctl_device{scsi_product=\"VIRTUAL-DISK\"}) < 1) OR vector(0)",
          "instant": true,
          "legendFormat": "__auto"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "With Pending Sectors",
      "description": "SMART 197: sectors awaiting reallocation. Data in these sectors may be unreadable.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "count((smartctl_device_attribute{attribute_name=\"Current_Pending_Sector\", attribute_value_type=\"raw\",device!~\".+megaraid.+\"} unless on(instance, device) smartctl_device{scsi_product=\"VIRTUAL-DISK\"}) > 0) OR vector(0)",
          "instant": true,
          "legendFormat": "__auto"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "With Reallocated Sectors",
      "description": "SMART 5: sectors remapped to spare area due to physical degradation.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "count((smartctl_device_attribute{attribute_name=\"Reallocated_Sector_Ct\", attribute_value_type=\"raw\",device!~\".+megaraid.+\"} unless on(instance, device) smartctl_device{scsi_product=\"VIRTUAL-DISK\"}) > 0) OR vector(0)",
          "instant": true,
          "legendFormat": "__auto"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Fleet Drive Health",
      "description": "Current SMART status for all monitored drives. Red cells require action. Click a row to investigate in Drive Detail.",
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max by (instance, device) (smartctl_device_smart_status{device!~\".+megaraid.+\"} unless on(instance, device) smartctl_device{scsi_product=\"VIRTUAL-DISK\"})",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max by (instance, device) (smartctl_device_temperature{temperature_type=\"current\",device!~\".+megaraid.+\"} unless on(instance, device) smartctl_device{scsi_product=\"VIRTUAL-DISK\"})",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max by (instance, device) (smartctl_device_attribute{attribute_name=\"Reallocated_Sector_Ct\",  attribute_value_type=\"raw\",device!~\".+megaraid.+\"} unless on(instance, device) smartctl_device{scsi_product=\"VIRTUAL-DISK\"})",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "D",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max by (instance, device) (smartctl_device_attribute{attribute_name=\"Current_Pending_Sector\", attribute_value_type=\"raw\",device!~\".+megaraid.+\"} unless on(instance, device) smartctl_device{scsi_product=\"VIRTUAL-DISK\"})",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "E",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max by (instance, device) (smartctl_device_attribute{attribute_name=\"Offline_Uncorrectable\",  attribute_value_type=\"raw\",device!~\".+megaraid.+\"} unless on(instance, device) smartctl_device{scsi_product=\"VIRTUAL-DISK\"})",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "F",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max by (instance, device) (smartctl_device_power_on_seconds{device!~\".+megaraid.+\"} unless on(instance, device) smartctl_device{scsi_product=\"VIRTUAL-DISK\"}) / 3600",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "type": true,
              "job": true
            },
            "renameByName": {
              "instance": "Host",
              "device": "Drive",
              "Value #A": "Health",
              "Value #B": "Temp (\u00b0C)",
              "Value #C": "Reallocated",
              "Value #D": "Pending Sectors",
              "Value #E": "Uncorrectable",
              "Value #F": "Power-On Hours"
            },
            "indexByName": {
              "instance": 0,
              "device": 1,
              "Value #A": 2,
              "Value #B": 3,
              "Value #C": 4,
              "Value #D": 5,
              "Value #E": 6,
              "Value #F": 7
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Health",
            "desc": false
          }
        ],
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "cellOptions": {
              "type": "auto"
            },
            "minWidth": 80
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Health"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "FAILED",
                        "color": "red",
                        "index": 0
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "1": {
                        "text": "PASSED",
                        "color": "green",
                        "index": 1
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "custom.width",
                "value": 90
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Temp (\u00b0C)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "celsius"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 45
                    },
                    {
                      "color": "red",
                      "value": 55
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Reallocated"
            },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 1
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Pending Sectors"
            },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "red",
                      "value": 1
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Uncorrectable"
            },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "red",
                      "value": 1
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "custom.width",
                "value": 110
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Power-On Hours"
            },
            "properties": [
              {
                "id": "unit",
                "value": "h"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 35040
                    },
                    {
                      "color": "orange",
                      "value": 43800
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Fleet Temperature Over Time",
      "description": "Drive temperatures across the entire fleet. Spikes indicate cooling events or workload surges.",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max by (instance, device) (smartctl_device_temperature{temperature_type=\"current\",device!~\".+megaraid.+\"} unless on(instance, device) smartctl_device{scsi_product=\"VIRTUAL-DISK\"})",
          "legendFormat": "{{instance}} / {{device}}"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "gradientMode": "none"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 45
              },
              {
                "color": "red",
                "value": 55
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Backblaze 5 \u2014 Fleet Trend (Reallocated, Pending, Uncorrectable, Command Timeout, Reported Uncorrectable)",
      "description": "The five SMART attributes most predictive of drive failure (Backblaze research). Any non-zero value on a healthy drive warrants investigation.",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max by (instance, device) (smartctl_device_attribute{attribute_name=\"Reallocated_Sector_Ct\",  attribute_value_type=\"raw\",device!~\".+megaraid.+\"} unless on(instance, device) smartctl_device{scsi_product=\"VIRTUAL-DISK\"})",
          "legendFormat": "{{instance}}/{{device}} Reallocated (5)"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max by (instance, device) (smartctl_device_attribute{attribute_name=\"Reported_Uncorrect\",       attribute_value_type=\"raw\",device!~\".+megaraid.+\"} unless on(instance, device) smartctl_device{scsi_product=\"VIRTUAL-DISK\"})",
          "legendFormat": "{{instance}}/{{device}} Reported Uncorrect (187)"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max by (instance, device) (smartctl_device_attribute{attribute_name=\"Command_Timeout\",          attribute_value_type=\"raw\",device!~\".+megaraid.+\"} unless on(instance, device) smartctl_device{scsi_product=\"VIRTUAL-DISK\"})",
          "legendFormat": "{{instance}}/{{device}} Command Timeout (188)"
        },
        {
          "refId": "D",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max by (instance, device) (smartctl_device_attribute{attribute_name=\"Current_Pending_Sector\",   attribute_value_type=\"raw\",device!~\".+megaraid.+\"} unless on(instance, device) smartctl_device{scsi_product=\"VIRTUAL-DISK\"})",
          "legendFormat": "{{instance}}/{{device}} Pending Sectors (197)"
        },
        {
          "refId": "E",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max by (instance, device) (smartctl_device_attribute{attribute_name=\"Offline_Uncorrectable\",    attribute_value_type=\"raw\",device!~\".+megaraid.+\"} unless on(instance, device) smartctl_device{scsi_product=\"VIRTUAL-DISK\"})",
          "legendFormat": "{{instance}}/{{device}} Uncorrectable (198)"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 0
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": false,
          "text": "grafanacloud-cew-prom",
          "value": "grafanacloud-prom"
        },
        "refresh": 1,
        "multi": false,
        "includeAll": false,
        "hide": 0
      },
      {
        "name": "logs_datasource",
        "label": "Loki",
        "type": "datasource",
        "query": "loki",
        "current": {
          "selected": false,
          "text": "grafanacloud-cew-logs",
          "value": "grafanacloud-logs"
        },
        "refresh": 1,
        "multi": false,
        "includeAll": false,
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}
